	"wm_getalldata": {
	"prefix": "wm_getalldata",
	 	"body": [
				"require_once \"__myTable.php\"; # Table Data Module",
				"\\$viewTableData= \\$myTable->getAllData(",
				"   array(",
				"    \"fields\"=>\"name,mobile,email\", # Data Table Fields",
				"    \"name\"=>\" like '%%'\" # SQL Query to get the data",
				" ),", 
				" \"html\",# Type of Data Display html: HTML Display | table: Display in Table Format | null: Data in PHP array", 
				" \"html/error.html\", # Error Handler Theme to Display",
				" \"users/usercard.html\", # Display HTML Theme to Browser",
				" [",
				"  [\"txt\",\"name\",\"Xname\",\"\",\"\"],",
				"  [\"txt\",\"mobile\",\"Xmobile\",\"\",\"\"],",
				"  [\"enc\",\"email\",\"Xemail\",\"\",\"\"]",
				" ],",
				" [",
				"  [\"txt\",\"Xname\",\"Xvname\",\"\",\"\"],",
				"  [\"txt\",\"List of Users\",\"Xtitle\",\"\",\"\"],",
				"  [\"txt\",\"?page=update_user&mobile=Xmobile\",\"XeditUrl\",\"\",\"\"],",
				"  [\"txt\",\"delete_user&mobile=Xmobile\",\"XdelUrl\",\"\",\"\"]",
				"]",
				");",
				"echo \\$viewTableData;"
	 	],
	 	"description": "Get All the Data from Database with SQL Query"
