	"wm_check_n_insert": {
	"prefix": "wm_check_n_insert",
	 	"body": [
				"if(isset(\\$_POST['name']))",
				"{",
				"require_once \"__myTable.php\"; # Table Data Module",
				" \\$res= \\$myTable->checkAndInsert(",
				"   array(",
				"   \"fields\"=>\"name,email,mobile,address,state,city,pincode\",# Table Fields",
				"   \"email\"=>\"'\".\\$_POST[\"email\"].\"' and  mobile='\".\\$_POST[\"mobile\"].\"'\" # SQL Query to Check",
				"   ),",
				"   \"User already exists with submitted data\",# Error Report to Display",
				"   \"Inserted\",# Success Report to Display",
				"   \"name,email,mobile,address,state,city,pincode\",# Table Fields to Enter Data",
				"  [",
				"   [\\$_POST[\"name\"],\\$_POST[\"email\"],\\$_POST[\"mobile\"],\\$_POST[\"address\"],\\$_POST[\"state\"],\\$_POST[\"city\"],\\$_POST[\"pincode\"]]",
				"  ],# Posted Values to Enter the Data to DB",
				"  \\$userFields # Posted Data Validation Settings in PHP Array",
				"  );",
				"  if(\\$res==\"Inserted\"){",
				"  unset(\\$_POST);",
				"  \\$wm->redir(\"?page=view_users\");",
				"  }else{",
				"   echo \\$res;",
				"  }",
				"}",
	 	],
	 	"description": "Check and insert Data into Database Table"
	 },
